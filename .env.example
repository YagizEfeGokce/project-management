# Database
DATABASE_URL="postgresql://taskflow:taskflow@localhost:5432/taskflow?schema=public"

# Security
JWT_SECRET="change-me-in-production"

# Server
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# CORS
CORS_ORIGIN="*"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Docker Compose Only
COMPOSE_PROJECT_NAME=taskflow
