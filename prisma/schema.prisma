generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id        Int      @id @default(autoincrement())
  name      String
  progress  Int      @default(0)
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  project     String
  status      String   @default("To Do")
  priority    String   @default("Medium")
  assignee    String   @default("Unassigned")
  dueDate     String?
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Risk {
  id        Int      @id @default(autoincrement())
  title     String
  category  String
  severity  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Stakeholder {
  id        Int      @id @default(autoincrement())
  name      String
  concern   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("member")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Comment {
  id        Int      @id @default(autoincrement())
  taskId    Int
  author    String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  actor     String
  action    String
  target    String?
  meta      String?
  createdAt DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
